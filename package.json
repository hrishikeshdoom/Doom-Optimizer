{
  "name": "doom-optimizer",
  "productName": "DOOM Optimizer",
  "version": "2.0.1",
  "description": "PC Gaming Performance Suite — Real Windows system-level optimizations",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:dir": "electron-builder --win --x64 --dir"
  },
  "build": {
    "appId": "com.doomoptimizer.app",
    "productName": "DOOM Optimizer",
    "copyright": "Copyright © 2024 DOOM Optimizer",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DOOM Optimizer",
      "include": "build/installer.nsh",
      "license": "build/license.txt",
      "installerSidebar": "assets/installer-sidebar.bmp"
    }
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "systeminformation": "^5.21.22"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "author": "DOOM Optimizer Team",
  "license": "MIT"
}
